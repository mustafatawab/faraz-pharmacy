generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid())
  username     String       @unique
  passwordHash String       @map("password_hash")
  role         String       @default("admin")
  createdAt    DateTime     @default(now()) @map("created_at")
  authTokens   AuthToken[]

  @@map("users")
}

model AuthToken {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  accessToken      String   @unique @map("access_token")
  refreshToken     String   @unique @map("refresh_token")
  csrfToken        String   @map("csrf_token")
  accessExpiresAt  DateTime @map("access_expires_at")
  refreshExpiresAt DateTime @map("refresh_expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_tokens")
}

model RecoveryKey {
  id        String    @id @default(uuid())
  keyHash   String    @map("key_hash")
  createdAt DateTime  @default(now()) @map("created_at")
  usedAt    DateTime? @map("used_at")

  @@map("recovery_keys")
}

model Product {
  id             String           @id @default(uuid())
  barcode        String           @unique
  name           String
  company        String           @default("")
  category       String           @default("")
  location       String           @default("")
  distributorId  String?          @map("distributor_id")
  salePrice      Float            @default(0) @map("sale_price")
  purchasePrice  Float            @default(0) @map("purchase_price")
  markupPercent  Float            @default(20) @map("markup_percent")
  stockQty       Int              @default(0) @map("stock_qty")
  expiry         String?
  active         Int              @default(1)
  createdAt      DateTime         @default(now()) @map("created_at")
  distributor    Distributor?     @relation(fields: [distributorId], references: [id])
  saleItems      SaleItem[]
  stockPurchases StockPurchase[]
  returnItems    ReturnItem[]

  @@map("products")
}

model Distributor {
  id         String    @id @default(uuid())
  name       String
  contact    String    @default("")
  phone      String    @default("")
  address    String    @default("")
  companyId  String?   @map("company_id")
  createdAt  DateTime  @default(now()) @map("created_at")
  company    Company?  @relation(fields: [companyId], references: [id])
  products   Product[]
  stockPurchases StockPurchase[]

  @@map("distributors")
}

model Company {
  id            String        @id @default(uuid())
  name          String
  contact       String        @default("")
  phone         String        @default("")
  secondNumber  String        @default("") @map("second_number")
  address       String        @default("")
  createdAt     DateTime      @default(now()) @map("created_at")
  distributors  Distributor[]
  stockPurchases StockPurchase[]

  @@map("companies")
}

model Customer {
  id        String    @id @default(uuid())
  name      String
  phone     String    @default("")
  address   String    @default("")
  createdAt DateTime  @default(now()) @map("created_at")
  sales     Sale[]
  arrears   Arrear[]

  @@map("customers")
}

model Sale {
  id         String     @id
  customerId String?    @map("customer_id")
  subtotal   Float      @default(0)
  discount   Float      @default(0)
  total      Float      @default(0)
  amountPaid Float      @default(0) @map("amount_paid")
  change     Float      @default(0)
  status     String     @default("paid")
  createdAt  DateTime   @default(now()) @map("created_at")
  customer   Customer?  @relation(fields: [customerId], references: [id])
  items      SaleItem[]
  returns    ReturnEntry[]
  arrears    Arrear[]

  @@map("sales")
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String  @map("sale_id")
  productId   String  @map("product_id")
  productName String  @map("product_name")
  barcode     String
  quantity    Int     @default(1)
  unitPrice   Float   @default(0) @map("unit_price")
  subtotal    Float   @default(0)
  sale        Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model Arrear {
  id         String   @id @default(uuid())
  saleId     String   @map("sale_id")
  customerId String   @map("customer_id")
  totalBill  Float    @default(0) @map("total_bill")
  amountPaid Float    @default(0) @map("amount_paid")
  balanceDue Float    @default(0) @map("balance_due")
  status     String   @default("pending")
  createdAt  DateTime @default(now()) @map("created_at")
  sale       Sale     @relation(fields: [saleId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])

  @@map("arrears")
}

model StockPurchase {
  id             String       @id @default(uuid())
  productId      String       @map("product_id")
  distributorId  String?      @map("distributor_id")
  companyId      String?      @map("company_id")
  invoiceNumber  String       @default("") @map("invoice_number")
  quantity       Int          @default(0)
  purchasePrice  Float        @default(0) @map("purchase_price")
  salePrice      Float        @default(0) @map("sale_price")
  expiry         String?
  totalValue     Float        @default(0) @map("total_value")
  createdAt      DateTime     @default(now()) @map("created_at")
  product        Product      @relation(fields: [productId], references: [id])
  distributor    Distributor? @relation(fields: [distributorId], references: [id])
  company        Company?     @relation(fields: [companyId], references: [id])

  @@map("stock_purchases")
}

model ReturnEntry {
  id           String       @id @default(uuid())
  saleId       String       @map("sale_id")
  refundAmount Float        @default(0) @map("refund_amount")
  reason       String       @default("")
  createdAt    DateTime     @default(now()) @map("created_at")
  sale         Sale         @relation(fields: [saleId], references: [id])
  items        ReturnItem[]

  @@map("returns")
}

model ReturnItem {
  id           String       @id @default(uuid())
  returnId     String       @map("return_id")
  productId    String       @map("product_id")
  productName  String       @map("product_name")
  quantity     Int          @default(0)
  refundAmount Float        @default(0) @map("refund_amount")
  returnEntry  ReturnEntry  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id])

  @@map("return_items")
}

model Expense {
  id        String   @id @default(uuid())
  title     String
  category  String
  amount    Float    @default(0)
  notes     String   @default("")
  date      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("expenses")
}
